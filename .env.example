# API Configuration
# Since .env is no longer bundled in the APK, use --dart-define to set the API URL:
#
# Development:
#   flutter run --dart-define=API_BASE_URL=http://localhost:5000
#
# Production:
#   flutter run --dart-define=API_BASE_URL=https://your-server.com
#
# The default value is http://localhost:5000
